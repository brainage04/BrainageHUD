{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "A mod that adds useful HUD elements to Minecraft.",
	"authors": [
		"brainage04"
	],
	"contact": {
		"homepage": "https://github.com/brainage04/BrainageHUD",
		"sources": "https://github.com/brainage04/BrainageHUD"
	},
	"license": "MIT",
	"icon": "assets/brainagehud/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"io.github.brainage04.brainagehud.BrainageHUD"
		],
		"fabric-datagen": [
			"io.github.brainage04.brainagehud.datagen.DataGenerator"
		],
		"modmenu": [
			"io.github.brainage04.brainagehud.modmenu.ModMenuIntegration"
		]
	},
	"mixins": [
		"brainagehud.client.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*",
		"cloth-config": ">=26.1.154",
		"hudrendererlib": ">=${hudrendererlib_version}"
	},
	"suggests": {
		"modmenu": "*"
	},
	"accessWidener": "brainagehud.accesswidener"
}
